        </div>

    </section>

    <!-- CHAT BOX -->

    <div class="fixedbox">
        👉🏻 Become a Member
    </div>



    <!--Contact -->
    <section class="contact">
    <h1>Contact Us</h1>

    <form class="contact-form">

        <label for="name">Name</label>
        <input class="xcv" type="text" id="name" placeholder="Enter your name">

        <label for="email">Email</label>
        <input class="xcv" type="email" id="email" placeholder="Enter your email">

        <label for="message">Message</label>
        <textarea class="xcv" id="message" rows="6" placeholder="Write your message..."></textarea>

        <button type="submit">Send Message</button>

    </form>
</section>

    <!-- FOOTER -->

    <footer>
        <p>© 2026 USSR History Project</p>
    </footer>

</body>
</html>
