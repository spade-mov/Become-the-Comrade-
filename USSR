<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Joseph Stalin - USSR</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
        }

        body{
            background-color: #ff0000;
            color: yellow;
        }

        /* =========================
           NAVBAR
        ========================= */
        nav{
            position: sticky;
            top: 0;
            height: 60px;
            background-color: red;

            display: flex;
            justify-content: center;
            align-items: center;
           }
        
           nav ul{
    display:flex;
    list-style:none;
    gap:40px;
    align-items:center;
}



        nav a{
            display: inline-block;
            text-decoration: none;
            color: white;
            font-size: 20px;
            transition: all 0.3s ease;
        }

        nav a:hover{
            transform: scale(1.1);
            color: yellow;
        }

        .logo{
              position: absolute;
              left: 20px;
            }
        .logo img{
                  width: 50px;
                  height: 50px;
                  border-radius: 50%;
                  object-fit: cover;
        }
     


        /* =========================
           HERO SECTION
        ========================= */

        .hero{
            position: relative;
            width: 100%;
            height: 100vh;
            overflow: hidden;
        }

.hero video{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

        .hero-text{
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            color: yellow;
            padding: 30px;
            border-radius: 10px;
        }

        .hero-text h1{
            font-size: 60px;
            margin-bottom: 15px;
        }

        .hero-text p{
            font-size: 22px;
            margin-bottom: 20px;
        }

        .hero-btn{
            display: inline-block;
            text-decoration: none;
            background-color: red;
            color: yellow;
            padding: 12px 25px;
            border-radius: 5px;
            transition: all 0.3s ease;
        }

        .hero-btn:hover{
            background-color: black;
            color: white;
            transform: scale(1.1);
        }

        /* =========================
           CONTENT
        ========================= */

        .content{
            padding: 50px;
            background: linear-gradient(rgb(255, 0, 0), rgb(255, 244, 179));
        }

        .content h2{
            margin-bottom: 20px;
            text-align: center;
            font-size: 40px;
        }

        .content p{
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.8;
            font-size: 18px;
            margin-bottom: 30px;
        }

        /* =========================
           CARDS
        ========================= */

        .container{
            display: flex;
            gap: 25px;
            flex-wrap: wrap;
            justify-content: center;
            margin-top: 30px;
        }

        .card{
            flex: 1;
            min-width: 300px;
            max-width: 380px;
            background: rgb(255, 0, 0);
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
        }

        .card:hover{
            transform: scale(1.1);
        }

        .card img{
            width: 100%;
            height: 250px;
            object-fit: cover;
            transition: all 0.3s ease;
        }
        .card img:hover{
            transform: scale(1.1);
        }

        .card-content{
            padding: 20px;
        }

        .card-content h3{
            margin-bottom: 15px;
            color: #ffd000;
        }

        .card-content p{

            color: #ffbf00;
            font-size: 16px;
            line-height: 1.6;
            margin-bottom: 0;
            flex-wrap: wrap;
        }

        /* =========================
           FIXED CHAT BOX
        ========================= */

        .fixedbox{
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: rgb(255, 0, 0);
            color: rgb(255, 234, 0);
            padding: 15px 20px;
            border-radius: 10px;
            cursor: pointer;
            box-shadow: 0 0 15px rgba(0,0,0,0.4);
            transition: all 0.3s ease;
        }

        .fixedbox:hover{
            background-color: #222;
            color: white;
            transform: scale(1.05);
        }

        /* =========================
           FOOTER
        ========================= */

        footer{
            background-color: #222;
            color: white;
            text-align: center;
            padding: 20px;
        }

        /* =========================
           RESPONSIVE
        ========================= */

        @media (max-width: 768px){

            nav ul{
                gap: 15px;
            }

            nav a{
                font-size: 16px;
            }

            .hero-text{
                width: 90%;
            }

            .hero-text h1{
                font-size: 36px;
            }

            .hero-text p{
                font-size: 18px;
            }

            .content{
                padding: 25px;
            }
        }
        .submit{
            background-color: red;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .submit:hover{
            background-color: black;
            color: white;
            transform: scale(1.1);
        }
        .contact{
    padding: 50px;
    background: #b30000;
}

.contact h1{
    text-align: center;
    color: yellow;
    margin-bottom: 30px;
    font-size: 40px;
}

.contact-form{
    max-width: 700px;
    margin: auto;
    background: rgb(255, 217, 0);
    padding: 30px;
    border-radius: 15px;
}

.contact-form label{
    display: block;
    margin-bottom: 8px;
    color: rgb(255, 0, 0);
    font-size: 18px;
}

.contact-form input,
.contact-form textarea{
    width: 100%;
    padding: 12px;
    margin-bottom: 20px;
    border: 2px solid #ff0000;
    border-radius: 8px;
    font-size: 16px;
    background-color: #ffbf00;
    color: rgb(255, 0, 0);
}

.contact-form textarea{
    resize: vertical;
}

.contact-form button{
    width: 100%;
    padding: 15px;
    border: none;
    border-radius: 8px;
    background: red;
    color: white;
    font-size: 18px;
    cursor: pointer;
    transition: 0.3s;
}

.contact-form button:hover{
    background: black;
    color: yellow;
}
.xcv::placeholder{
    color: black;
}

    </style>
</head>

<body>

    <!-- NAVBAR -->

    <nav>
        <div class="logo">
